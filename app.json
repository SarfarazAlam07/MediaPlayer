{
  "expo": {
    "name": "HybridPlayer",
    "slug": "HybridPlayer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "hybridplayer",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "android": {
      "package": "com.sarfarazalam.hybridplayer",
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_MEDIA_LOCATION",
        "RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-media-library",
      "expo-navigation-bar",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "minSdkVersion": 24,
            "enableProguardInReleaseBuilds": false
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "2ddfb143-8c3b-4953-84a0-6aedad5080b3"
      }
    }
  }
}